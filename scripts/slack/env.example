# AgentSpace Slack smoke dry-run environment.
# Generate a filled copy with:
# agent-space integrations slack smoke-env --workspace-id default --integration CHANGE_ME_SLACK_INTEGRATION_ID --app-url https://agentspace.example.com > scripts/slack/.env

AGENT_SPACE_WORKSPACE_ID=default
AGENT_SPACE_SLACK_INTEGRATION_ID=CHANGE_ME_SLACK_INTEGRATION_ID
AGENT_SPACE_PUBLIC_APP_URL=https://agentspace.example.com
SLACK_SMOKE_CALLBACK_URL=https://agentspace.example.com/api/integrations/slack/events

# Use disposable Slack conversation/user ids for local smoke. Do not commit filled copies.
SLACK_SMOKE_CHANNEL_ID=CHANGE_ME_SLACK_CHANNEL_ID
SLACK_SMOKE_USER_ID=CHANGE_ME_SLACK_USER_ID
SLACK_SMOKE_APP_ID=CHANGE_ME_SLACK_APP_ID
SLACK_SMOKE_TEAM_ID=CHANGE_ME_SLACK_TEAM_ID
SLACK_SMOKE_BOT_USER_ID=
SLACK_SMOKE_MESSAGE_TEXT=AgentSpace Slack smoke
SLACK_SMOKE_THREAD_TS=

# Optional live mode:
# - post_message: uses SLACK_BOT_TOKEN to send a disposable chat.postMessage smoke message.
# - app_mention: uses SLACK_SMOKE_POST_TOKEN to post "<@SLACK_SMOKE_BOT_USER_ID> ..." from a non-AgentSpace sender
#   so Slack can deliver a real app_mention callback to AgentSpace.
# - file_upload: uses SLACK_BOT_TOKEN to upload a disposable file through Slack's external upload flow.
SLACK_SMOKE_LIVE_MODE=post_message
SLACK_SMOKE_POST_TOKEN=
SLACK_SMOKE_FILE_NAME=agentspace-slack-smoke.txt
SLACK_SMOKE_FILE_TITLE=AgentSpace Slack smoke file
SLACK_SMOKE_FILE_CONTENT=AgentSpace Slack file smoke
SLACK_SMOKE_FILE_MIME=text/plain

# Required only for --live or agent bot binding. Prefer exporting these in the shell instead of saving them.
SLACK_BOT_TOKEN=CHANGE_ME_SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=CHANGE_ME_SLACK_SIGNING_SECRET
SLACK_APP_TOKEN=CHANGE_ME_SLACK_APP_TOKEN
# Optional test override. Defaults to https://slack.com/api.
SLACK_API_BASE_URL=
# Optional test override for --replay-webhook. Keep empty outside local fake callback tests.
AGENT_SPACE_SMOKE_CALLBACK_BASE_URL=

# Manual actions before final --require all:
# - native_agent_experience: Open the Slack app Messages tab, then send one app-context DM or agent-view message so AgentSpace records app context, app-home welcome, and assistant suggested prompt evidence.
# - approval_block_actions: Trigger one AgentSpace runtime approval card in Slack and approve or reject it so AgentSpace records processed block_actions evidence and an approval status outbox receipt.

# Suggested verification order:
# - agent-space integrations slack health-check --workspace-id default --integration CHANGE_ME_SLACK_INTEGRATION_ID --json
# - agent-space integrations slack readiness --workspace-id default --integration CHANGE_ME_SLACK_INTEGRATION_ID --strict --json
# - npm run smoke:slack -- --env-file scripts/slack/.env --check-env --json
# - npm run smoke:slack -- --env-file scripts/slack/.env --replay-webhook --json
# - npm run smoke:slack -- --env-file scripts/slack/.env --live --evidence runtime-output/slack-smoke/live.json --json
# - SLACK_SMOKE_LIVE_MODE=app_mention npm run smoke:slack -- --env-file scripts/slack/.env --live --evidence runtime-output/slack-smoke/live.json --json
# - agent-space integrations slack outbox drain --workspace-id default --integration CHANGE_ME_SLACK_INTEGRATION_ID --json
# - SLACK_SMOKE_LIVE_MODE=file_upload npm run smoke:slack -- --env-file scripts/slack/.env --live --evidence runtime-output/slack-smoke/live.json --json
# - npm run smoke:slack:verify -- --env-file scripts/slack/.env --json
# - agent-space integrations slack evidence --workspace-id default --integration CHANGE_ME_SLACK_INTEGRATION_ID --live-smoke-evidence runtime-output/slack-smoke/live.json --strict --require all --json

# Optional inbound file scan command for webhook/worker runs that download Slack files.
# The command receives file bytes on stdin. For ClamAV, use:
# AGENT_SPACE_SLACK_ATTACHMENT_SCAN_COMMAND=/usr/bin/clamscan
# AGENT_SPACE_SLACK_ATTACHMENT_SCAN_ARGS=["--no-summary","-"]
AGENT_SPACE_SLACK_ATTACHMENT_SCAN_COMMAND=
AGENT_SPACE_SLACK_ATTACHMENT_SCAN_ARGS=
AGENT_SPACE_SLACK_ATTACHMENT_SCAN_ENGINE=
AGENT_SPACE_SLACK_ATTACHMENT_SCAN_TIMEOUT_MS=30000
AGENT_SPACE_SLACK_ATTACHMENT_SCAN_BLOCK_EXIT_CODES=1
