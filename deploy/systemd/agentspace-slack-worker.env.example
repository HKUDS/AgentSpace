# AgentSpace Slack Socket Mode worker environment.
# Copy to /etc/agentspace/slack-worker.env for deploy/systemd/agentspace-slack-worker.service.

AGENT_SPACE_WORKSPACE_ID=default

# PostgreSQL primary database. Use the same database as the AgentSpace web app.
AGENT_SPACE_PG_URL=postgres://agent_space:agent_space@127.0.0.1:5432/agent_space
DATABASE_URL=postgres://agent_space:agent_space@127.0.0.1:5432/agent_space

# Required to decrypt Slack bot_token / signing_secret / app_level_token saved by the web UI or CLI.
# Must match the key used by the web app when the Slack integration was created.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AGENT_SPACE_SLACK_CREDENTIAL_ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_key

# Optional: restrict this worker to one integration id.
AGENT_SPACE_SLACK_INTEGRATION_ID=

# Optional: identify this worker in outbox locks and logs.
AGENT_SPACE_SLACK_WORKER_ID=slack-worker-prod-01

# Optional: override Slack Web API base URL for private/test environments.
AGENT_SPACE_SLACK_API_BASE_URL=
