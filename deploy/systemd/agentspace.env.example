# AgentSpace Web environment.
# Copy to /etc/agentspace/web.env for deploy/systemd/agentspace.service.

AGENT_SPACE_APP_URL=https://agentspace.example.com

# PostgreSQL primary database.
AGENT_SPACE_PG_URL=postgres://agent_space:agent_space@127.0.0.1:5432/agent_space
DATABASE_URL=postgres://agent_space:agent_space@127.0.0.1:5432/agent_space

# Required for stable Next.js Server Action IDs across rebuilds and web instances.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_key

# Used to sign OAuth state / nonce cookies.
AGENT_SPACE_OAUTH_STATE_SECRET=replace_with_a_long_random_hex_string

# Optional Google OAuth.
AGENT_SPACE_GOOGLE_CLIENT_ID=
AGENT_SPACE_GOOGLE_CLIENT_SECRET=
AGENT_SPACE_GOOGLE_CALLBACK_URL=https://agentspace.example.com/api/auth/google/callback

# Optional Google Workspace / Google Sheets integration.
AGENT_SPACE_GOOGLE_WORKSPACE_CLIENT_ID=
AGENT_SPACE_GOOGLE_WORKSPACE_CLIENT_SECRET=
AGENT_SPACE_GOOGLE_WORKSPACE_CALLBACK_URL=https://agentspace.example.com/api/integrations/google/callback
AGENT_SPACE_GOOGLE_WORKSPACE_TOKEN_ENCRYPTION_KEY=
AGENT_SPACE_GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Optional Slack OAuth "Add to Slack" install.
# The signing secret still comes from the Slack app settings; Slack OAuth does not return it.
AGENT_SPACE_SLACK_CREDENTIAL_ENCRYPTION_KEY=
AGENT_SPACE_SLACK_CLIENT_ID=
AGENT_SPACE_SLACK_CLIENT_SECRET=
AGENT_SPACE_SLACK_SIGNING_SECRET=
AGENT_SPACE_SLACK_OAUTH_CALLBACK_URL=https://agentspace.example.com/api/integrations/slack/oauth/callback
AGENT_SPACE_SLACK_APP_LEVEL_TOKEN=
AGENT_SPACE_SLACK_API_BASE_URL=
